DATABASE_URL=postgresql://user:password@localhost:5432/swiftza

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# Cookies
COOKIE_DOMAIN=localhost
NODE_ENV=development

# Storefront & Admin URLs
STOREFRONT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:3003

# Crypto
CRYPTO_WALLET_ADDRESS=0x1234567890123456789012345678901234567890
CRYPTO_NETWORK=BSC
CRYPTO_RATE_SOURCE=coingecko

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

KLARNA_API_KEY=...
AFFIRM_PUBLIC_API_KEY=...

# Email
RESEND_API_KEY=re_...
SENDER_EMAIL=noreply@swiftza-store.com

# Storage
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=swiftza
R2_REGION=us

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=...

# Shipping
EASYPOST_API_KEY=...

# Redis (for sessions, caching, jobs)
REDIS_URL=redis://localhost:6379

# Monitoring
SENTRY_DSN=...
LOGTAIL_TOKEN=...
